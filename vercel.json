{
  "version": 2,
  "name": "lungguard-dashboard",
  "builds": [
    {
      "src": "aerolung-dashboard/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "aerolung-dashboard/dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "buildCommand": "cd aerolung-dashboard && npm install && npm run build",
  "outputDirectory": "aerolung-dashboard/dist",
  "installCommand": "cd aerolung-dashboard && npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
