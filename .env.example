 # AeroLung Backend Environment Variables
# Copy this file to .env and fill in your actual API keys.
# NEVER commit .env to version control.

# ─── External API Keys ────────────────────────────────────────────────────────
# OpenWeatherMap API key (for city-level AQI data)
# Get yours at: https://openweathermap.org/api
OWM_API_KEY=your_openweathermap_api_key_here

# OpenAQ API key (for granular sensor node readings)
# Get yours at: https://openaq.org/
OPENAQ_API_KEY=your_openaq_api_key_here

# ─── Server Configuration ─────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── CORS Origins ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── JWT Authentication (FIX 1.1) ────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_random_256bit_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=1440
